{
	"name": "@ruah-dev/cli",
	"version": "1.1.3",
	"description": "CLI for ruah — multi-agent developer toolkit. Workspace isolation, file locking, DAG scheduling, merge coordination.",
	"type": "module",
	"files": [
		"postinstall.mjs",
		"dist/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsc && node dist/postbuild.js",
		"dev": "tsc --watch",
		"postinstall": "node postinstall.mjs",
		"prepare": "npm run build",
		"pretest": "npm run build",
		"test": "node dist/verify.js",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist",
		"verify": "npm run typecheck && npm run lint && npm test",
		"prepublishOnly": "npm run clean && npm run build && npm test"
	},
	"keywords": [
		"ai",
		"agents",
		"orchestration",
		"multi-agent",
		"claude-code",
		"codex",
		"aider",
		"cursor",
		"worktree",
		"workflow",
		"cli"
	],
	"author": "ruah-dev",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ruah-dev/ruah-cli.git"
	},
	"bugs": {
		"url": "https://github.com/ruah-dev/ruah-cli/issues"
	},
	"homepage": "https://github.com/ruah-dev/ruah-cli#readme",
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"@ruah-dev/conv-core": "^0.2.0",
		"@ruah-dev/orch-core": "file:../ruah-orch/packages/core"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.2",
		"typescript": "^6.0.2"
	}
}
